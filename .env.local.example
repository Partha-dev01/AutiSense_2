# ═══════════════════════════════════════════════════
# AutiSense Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════

# ── AWS Core ──────────────────────────────────────
# For local dev, use AWS CLI profiles (~/.aws/credentials) OR these env vars:
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Amplify Custom Credentials (production only) ─
# Amplify blocks AWS_* prefix — these are used by app/lib/aws/credentials.ts
# On Amplify, set via Console → Environment Variables (app-level)
APP_ACCESS_KEY_ID=
APP_SECRET_ACCESS_KEY=
APP_REGION=ap-south-1

# ── DynamoDB Tables ───────────────────────────────
DYNAMODB_SESSIONS_TABLE=autisense-sessions
DYNAMODB_BIOMARKERS_TABLE=autisense-biomarkers
DYNAMODB_USERS_TABLE=autisense-users
DYNAMODB_AUTH_SESSIONS_TABLE=autisense-auth-sessions
DYNAMODB_CHILD_PROFILES_TABLE=autisense-child-profiles
DYNAMODB_SESSION_SUMMARIES_TABLE=autisense-session-summaries
DYNAMODB_FEED_POSTS_TABLE=autisense-feed-posts

# ── S3 ────────────────────────────────────────────
S3_MODELS_BUCKET=autisense-models

# ── Amazon Bedrock ────────────────────────────────
BEDROCK_REGION=us-east-1

# ── Amazon Polly ──────────────────────────────────
POLLY_REGION=ap-south-1

# ── Google OAuth ──────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
